{
  "kind": "collectionType",
  "collectionName": "plans",
  "info": {
    "singularName": "plan",
    "pluralName": "plans",
    "displayName": "plan",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "address": {
      "type": "string",
      "unique": true
    },
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "string",
      "unique": true,
      "regex": "^[a-z0-9\\-]*$"
    },
    "svg": {
      "type": "text"
    },
    "notes": {
      "type": "richtext"
    },
    "jobber": {
      "type": "integer",
      "unique": true
    },
    "areas": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::area.area",
      "inversedBy": "plans"
    },
    "zip": {
      "type": "integer"
    },
    "timerHours": {
      "type": "integer"
    },
    "timerFallback": {
      "type": "string"
    },
    "basicNotes": {
      "type": "text"
    },
    "relatedPlans": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::plan.plan",
      "inversedBy": "plans"
    },
    "plans": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::plan.plan",
      "mappedBy": "relatedPlans"
    }
  }
}
